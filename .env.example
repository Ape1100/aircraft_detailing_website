# ── Supabase ──────────────────────────────────────────────────────────────────
# Settings > API in your Supabase project dashboard.
# The VITE_ variants are exposed to the frontend (safe for anon key only).
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are used server-side only
# (netlify/functions) — never expose the service role key to the browser.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Use sk_test_ / pk_test_ keys during development; swap for sk_live_ / pk_live_
# in production (Netlify env vars). The secret key and webhook secret are used
# ONLY in netlify/functions — never in frontend code or committed to git.
# Note: VITE_STRIPE_PUBLISHABLE_KEY is declared but not currently used by the
# app (all Stripe flows use server-side Checkout sessions, not Stripe.js
# directly), so only STRIPE_SECRET_KEY matters for functionality.
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Resend (transactional email) ──────────────────────────────────────────────
# Create an account at resend.com, verify your sending domain, and generate
# an API key. RESEND_FROM_EMAIL must be an address on a verified domain.
# Used in netlify/functions (send-report-email, stripe-webhook receipt emails).
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Site URL ──────────────────────────────────────────────────────────────────
# Used by netlify/functions to construct redirect URLs after Stripe Checkout.
# Set to http://localhost:5173 locally; Netlify sets this automatically for
# deployed previews and production via the SITE_URL env var in the dashboard.
SITE_URL=http://localhost:5173
