# Supabase
# TODO: create a Supabase project, then fill these in.
# Settings > API in your Supabase dashboard.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe
# TODO: create a Stripe account (or use test mode) and fill these in.
# Publishable key is safe for the frontend. Secret key is used ONLY in
# the serverless functions under netlify/functions — never expose it
# in frontend code or commit it to git.
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Used by netlify/functions to construct redirect URLs after checkout
SITE_URL=http://localhost:5173
